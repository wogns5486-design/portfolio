---
import PageLayout from './PageLayout.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  ogImage?: string;
}

const { title, description, pubDate, tags = [], ogImage } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<PageLayout title={`${title} — ONESTEP 블로그`} description={description} ogImage={ogImage}>

  <!-- Back link -->
  <section class="px-7 pt-10 pb-0">
    <div class="max-w-[720px] mx-auto">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-primary transition-colors group">
        <span class="transition-transform group-hover:-translate-x-1">←</span> 블로그 목록
      </a>
    </div>
  </section>

  <!-- Post header -->
  <section class="relative px-7 pt-8 pb-10 overflow-hidden">
    <div class="absolute -top-[80px] left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-[radial-gradient(circle,rgba(99,102,241,0.15),transparent_65%)] pointer-events-none"></div>
    <div class="relative z-10 max-w-[720px] mx-auto">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-5">
          {tags.map(tag => (
            <span class="px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-medium">{tag}</span>
          ))}
        </div>
      )}

      <h1 class="text-[clamp(1.8rem,4.5vw,2.8rem)] font-black tracking-tight text-text-main mb-4 break-keep leading-[1.2]">
        {title}
      </h1>

      {description && (
        <p class="text-text-sub text-[1.05rem] leading-relaxed mb-6 break-keep">{description}</p>
      )}

      <!-- Meta -->
      <div class="flex items-center gap-4 text-xs text-text-muted border-t border-border-light pt-5">
        <span>{formattedDate}</span>
        <span class="w-1 h-1 rounded-full bg-border-light"></span>
        <span>ONESTEP</span>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="px-7 pb-16">
    <div class="max-w-[720px] mx-auto blog-content">
      <slot />
    </div>
  </section>

  <!-- Back to blog CTA -->
  <section class="px-7 pb-16">
    <div class="max-w-[720px] mx-auto">
      <div class="section-divider mb-8"></div>
      <div class="flex items-center justify-between">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-primary transition-colors group">
          <span class="transition-transform group-hover:-translate-x-1">←</span> 블로그로 돌아가기
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-gradient-to-r from-primary-deep to-primary text-white text-xs font-bold transition-all hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(99,102,241,0.4)]">
          프로젝트 문의 →
        </a>
      </div>
    </div>
  </section>

</PageLayout>

<style is:global>
  .blog-content {
    font-size: 1rem;
    line-height: 1.8;
    color: #94A3B8;
  }

  .blog-content h2 {
    font-size: 1.35rem;
    font-weight: 800;
    color: #F1F5F9;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-left: 0.75rem;
    border-left: 3px solid #818CF8;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .blog-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #F1F5F9;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .blog-content h4 {
    font-size: 1rem;
    font-weight: 600;
    color: #F1F5F9;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .blog-content p {
    margin-bottom: 1.25rem;
    line-height: 1.8;
  }

  .blog-content a {
    color: #818CF8;
    text-decoration: none;
    border-bottom: 1px solid rgba(129, 140, 248, 0.3);
    transition: border-color 0.2s;
  }

  .blog-content a:hover {
    border-bottom-color: #818CF8;
  }

  .blog-content strong {
    color: #F1F5F9;
    font-weight: 600;
  }

  .blog-content em {
    color: #CBD5E1;
  }

  .blog-content ul,
  .blog-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-content ul {
    list-style-type: disc;
  }

  .blog-content ol {
    list-style-type: decimal;
  }

  .blog-content li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }

  .blog-content li::marker {
    color: #818CF8;
  }

  .blog-content code {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.85em;
    background: #1E293B;
    color: #818CF8;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    border: 1px solid rgba(148, 163, 184, 0.08);
  }

  .blog-content pre {
    background: #111827;
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 12px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .blog-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: #CBD5E1;
    font-size: inherit;
  }

  .blog-content blockquote {
    border-left: 2px solid #818CF8;
    background: rgba(17, 24, 39, 0.5);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #64748B;
  }

  .blog-content blockquote p {
    margin-bottom: 0;
  }

  .blog-content hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(148, 163, 184, 0.12), transparent);
    margin: 2rem 0;
  }

  .blog-content img {
    border-radius: 12px;
    border: 1px solid rgba(148, 163, 184, 0.08);
    margin: 1.5rem 0;
    max-width: 100%;
  }

  .blog-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .blog-content th {
    background: #1E293B;
    color: #F1F5F9;
    font-weight: 600;
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  }

  .blog-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.08);
  }
</style>
