---
import BaseLayout from './BaseLayout.astro';
import Header from '@components/common/Header.astro';
import Footer from '@components/common/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const isContactPage = Astro.url.pathname === '/contact' || Astro.url.pathname === '/contact/';
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <Header />
  <main class="pt-16 min-h-screen">
    <slot />
  </main>
  <Footer />

  <!-- Back to Top button -->
  <button
    id="back-to-top"
    aria-label="맨 위로 이동"
    class="fixed bottom-24 right-6 z-50 w-10 h-10 rounded-full bg-surface border border-border-light text-text-muted flex items-center justify-center shadow-lg transition-all duration-300 hover:border-primary/40 hover:text-primary hover:shadow-[0_4px_20px_rgba(99,102,241,0.25)] opacity-0 pointer-events-none translate-y-2"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <!-- Floating contact button (hidden on contact page) -->
  {!isContactPage && (
    <div id="floating-contact-wrap" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2">
      <!-- Tooltip speech bubble -->
      <div id="floating-tooltip" class="floating-tooltip" aria-hidden="true">
        프로젝트 문의하기
      </div>
      <!-- Button -->
      <a
        id="floating-contact"
        href="/contact"
        aria-label="프로젝트 문의하기"
        class="floating-btn flex items-center gap-2 px-4 py-3 rounded-full bg-[#6366F1] text-white text-sm font-semibold shadow-[0_4px_20px_rgba(99,102,241,0.45)] transition-all duration-300"
      >
        <!-- Chat bubble SVG icon -->
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        문의
      </a>
    </div>
  )}
</BaseLayout>

<style>
  /* Bounce animation for attention grab */
  @keyframes subtle-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  .floating-btn {
    animation: subtle-bounce 2.2s ease-in-out infinite;
  }
  .floating-btn:hover {
    animation: none;
    transform: scale(1.1);
    box-shadow: 0 8px 32px rgba(99, 102, 241, 0.6);
  }

  /* Speech bubble tooltip */
  .floating-tooltip {
    position: relative;
    background: var(--color-surface, #1e1e2e);
    border: 1px solid rgba(99, 102, 241, 0.25);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.4rem 0.85rem;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
  }
  /* Arrow pointing down-right toward the button */
  .floating-tooltip::after {
    content: '';
    position: absolute;
    bottom: -6px;
    right: 18px;
    width: 10px;
    height: 10px;
    background: var(--color-surface, #1e1e2e);
    border-right: 1px solid rgba(99, 102, 241, 0.25);
    border-bottom: 1px solid rgba(99, 102, 241, 0.25);
    transform: rotate(45deg);
  }
  .floating-tooltip.visible {
    opacity: 1;
  }
</style>

<script is:inline>
  function initFloatingContact() {
    var tooltip = document.getElementById('floating-tooltip');
    if (!tooltip) return;

    var hideTimer = null;
    var cycleTimer = null;

    function showTooltip() {
      tooltip.classList.add('visible');
      hideTimer = setTimeout(function() {
        tooltip.classList.remove('visible');
      }, 3000);
    }

    function startCycle() {
      // Show immediately on first load, then repeat every 30s
      showTooltip();
      cycleTimer = setInterval(showTooltip, 30000);
    }

    // Small delay so it appears after page settles
    var startTimer = setTimeout(startCycle, 1200);

    // Cleanup on page navigation
    function cleanup() {
      clearTimeout(hideTimer);
      clearTimeout(startTimer);
      clearInterval(cycleTimer);
    }
    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }

  initFloatingContact();
  document.addEventListener('astro:page-load', initFloatingContact);
</script>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const backToTop = document.getElementById('back-to-top');
    if (!backToTop) return;

    const onScroll = () => {
      if (window.scrollY > 300) {
        backToTop.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-2');
        backToTop.classList.add('opacity-100', 'translate-y-0');
      } else {
        backToTop.classList.add('opacity-0', 'pointer-events-none', 'translate-y-2');
        backToTop.classList.remove('opacity-100', 'translate-y-0');
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
