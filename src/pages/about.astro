---
import PageLayout from '@layouts/PageLayout.astro';
---

<PageLayout title="ONESTEP 소개 — AI 기반 개발 조직" description="20+ AI 에이전트가 기획부터 배포, QA, 보안 검토까지. 한 사람의 가능성을 100배로 만드는 ONESTEP.">

  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center px-7 pt-[80px] pb-16 text-center overflow-hidden">
    <div class="absolute -top-[200px] left-1/2 -translate-x-1/2 w-[900px] h-[800px] bg-[radial-gradient(circle,rgba(99,102,241,0.22),rgba(129,140,248,0.08)_45%,transparent_70%)] pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[radial-gradient(ellipse,rgba(99,102,241,0.10),transparent_60%)] pointer-events-none"></div>

    <div class="relative z-10 max-w-[760px] mx-auto">
      <p class="text-[0.72rem] tracking-[4px] text-primary uppercase mb-5 font-semibold">ABOUT ONESTEP</p>
      <h1 class="text-[clamp(2.4rem,6vw,3.8rem)] font-black leading-[1.1] tracking-tight mb-6 break-keep">
        단순한 개발자가 아닌,<br />
        <span class="gradient-text">AI 기반 개발 조직</span>
      </h1>
      <p class="text-text-sub text-[1rem] leading-relaxed max-w-[580px] mx-auto break-keep">
        ONESTEP은 20개 이상의 전문 AI 에이전트로 구성된 개발 조직입니다.
        기획부터 배포, QA, 보안 검토까지 — 한 사람의 가능성을 100배로 만듭니다.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Stats -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-10 text-center">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">Numbers</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">숫자로 보는 ONESTEP</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {[
          {
            value: '102+',
            label: '프로젝트',
            sub: '다양한 산업군 경험',
            icon: '📦',
          },
          {
            value: '11건',
            label: '위시켓 수주',
            sub: '검증된 외부 수주 실적',
            icon: '🏆',
          },
          {
            value: '3개',
            label: 'LIVE 서비스',
            sub: '실제 운영 중인 서비스',
            icon: '🟢',
          },
        ].map(stat => (
          <div class="bg-surface border border-border-light rounded-card p-8 text-center transition-all hover:-translate-y-1 hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/[0.04] to-transparent pointer-events-none"></div>
            <div class="relative">
              <div class="text-3xl mb-3">{stat.icon}</div>
              <div class="text-[2.4rem] font-black leading-none gradient-text mb-2">{stat.value}</div>
              <div class="text-[0.95rem] font-semibold text-text-main mb-1">{stat.label}</div>
              <div class="text-[0.78rem] text-text-muted">{stat.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Story -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-3 font-semibold">Our Story</p>
          <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight mb-6 break-keep">
            "한 사람의 가능성을<br />100배로"
          </h2>
          <div class="space-y-4 text-text-sub text-[0.9rem] leading-relaxed">
            <p class="break-keep">
              ONESTEP은 한 가지 질문에서 시작했습니다.
              <em class="text-text-main not-italic font-medium">"한 사람이 할 수 있는 일의 한계는 어디까지일까?"</em>
            </p>
            <p class="break-keep">
              답은 AI에 있었습니다. 20개 이상의 전문 AI 에이전트를 조직화하여, 전략기획부터 개발, QA, 보안 검토, 배포까지
              <strong class="text-primary">완전한 개발 조직</strong>을 구축했습니다.
            </p>
            <p class="break-keep">
              그 결과, 시장 평균보다 <strong class="text-primary">30% 합리적인 가격</strong>에
              타협 없는 퀄리티를 제공합니다.
              102개 프로젝트, 11건의 위시켓 수주, 3개의 LIVE 서비스가 그 증거입니다.
            </p>
          </div>
        </div>

        <!-- Timeline cards -->
        <div class="space-y-4">
          {[
            { year: '2022', label: '첫 프로젝트', desc: '소규모 쇼핑몰 개발을 시작으로 실전 경험 축적' },
            { year: '2023', label: '위시켓 진출', desc: '외부 플랫폼에서 11건 수주. 다양한 클라이언트 경험' },
            { year: '2024', label: 'LIVE 서비스 런칭', desc: '3개의 자체 서비스를 직접 기획·개발·운영' },
            { year: '2025', label: 'AI 조직 완성', desc: '20+ AI 에이전트 팀 구축. 102개 프로젝트 돌파' },
          ].map(item => (
            <div class="flex gap-4 bg-surface border border-border-light rounded-[14px] p-5 transition-all hover:border-primary/20 hover:-translate-y-0.5">
              <div class="shrink-0 w-14 text-center">
                <span class="text-xs font-bold text-primary">{item.year}</span>
              </div>
              <div>
                <p class="text-sm font-bold text-text-main mb-0.5">{item.label}</p>
                <p class="text-xs text-text-sub leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Vision & Mission -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-10 text-center">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">Vision & Mission</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">우리가 추구하는 것</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Vision -->
        <div class="bg-surface border border-border-light rounded-card p-8 relative overflow-hidden group hover:-translate-y-1 transition-all hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)]">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-primary/10 to-transparent rounded-bl-[100px] pointer-events-none"></div>
          <div class="relative">
            <div class="text-2xl mb-4">🔭</div>
            <p class="text-xs font-bold text-primary tracking-wider uppercase mb-3">Vision</p>
            <h3 class="text-xl font-bold text-text-main mb-3 break-keep leading-snug">
              한 사람의 가능성을<br />100배로
            </h3>
            <p class="text-sm text-text-sub leading-relaxed break-keep">
              AI와 사람이 협업하면, 한 사람도 전문 조직과 같은 결과를 만들 수 있습니다.
              ONESTEP은 그 가능성을 증명합니다.
            </p>
          </div>
        </div>

        <!-- Mission -->
        <div class="bg-surface border border-border-light rounded-card p-8 relative overflow-hidden group hover:-translate-y-1 transition-all hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)]">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-primary/10 to-transparent rounded-bl-[100px] pointer-events-none"></div>
          <div class="relative">
            <div class="text-2xl mb-4">🎯</div>
            <p class="text-xs font-bold text-primary tracking-wider uppercase mb-3">Mission</p>
            <h3 class="text-xl font-bold text-text-main mb-3 break-keep leading-snug">
              합리적인 가격,<br />타협 없는 퀄리티
            </h3>
            <p class="text-sm text-text-sub leading-relaxed break-keep">
              AI 에이전트 팀을 통해 비용은 30% 절감하면서도, 기획-개발-QA-보안 검토까지
              빈틈없는 프로세스를 제공합니다.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- AI Agent Team -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-4 text-center">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">Our Team</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">AI 에이전트 팀</h2>
        <p class="text-sm text-text-sub mt-3 max-w-[560px] mx-auto leading-relaxed">단순한 AI 도구 활용이 아닙니다. 각 분야별 전문 에이전트가 조직처럼 협업합니다.</p>
      </div>

      <div class="flex justify-center mb-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20">
          <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
          <span class="text-xs font-semibold text-primary">20+ 에이전트 활성</span>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: '🧠', dept: '전략기획실', role: '사업 방향, 프로젝트 설계, 아키텍처 결정', agents: ['Planner', 'Analyst', 'Architect', 'Critic'] },
          { icon: '💻', dept: '개발팀', role: '코드 작성, 디버깅, 배포', agents: ['Executor', 'Debugger', 'Git Master', 'Code Simplifier'] },
          { icon: '✅', dept: 'QA팀', role: '테스트, 코드 리뷰, 시각 검수', agents: ['Verifier', 'Code Reviewer', 'QA Tester', 'Test Engineer'] },
          { icon: '🛡️', dept: '보안팀', role: '취약점 검사, 보안 감사', agents: ['Security Reviewer'] },
          { icon: '🎨', dept: '크리에이티브팀', role: 'UI/UX 디자인, 문서, 콘텐츠', agents: ['Designer', 'Writer'] },
          { icon: '🔬', dept: '리서치팀', role: '정보수집, 트렌드 분석, 보고서', agents: ['Scientist', 'Document Specialist'] },
        ].map(item => (
          <div class="bg-surface border border-border-light rounded-card p-6 transition-all hover:-translate-y-1 hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)] relative overflow-hidden group">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/[0.04] to-transparent pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="flex items-center gap-3 mb-4">
                <div class="text-2xl">{item.icon}</div>
                <div>
                  <h3 class="text-base font-bold text-text-main">{item.dept}</h3>
                  <p class="text-xs text-text-muted">{item.role}</p>
                </div>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {item.agents.map(agent => (
                  <span class="px-2.5 py-1 rounded-full bg-primary/10 border border-primary/15 text-[0.65rem] text-primary font-medium">
                    {agent}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- PDCA Workflow -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-10 text-center">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">PDCA Workflow</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">AI 기반 품질 관리 프로세스</h2>
        <p class="text-sm text-text-sub mt-3 max-w-[520px] mx-auto leading-relaxed">모든 프로젝트는 PDCA 사이클을 통해 체계적으로 관리됩니다.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-5">
        {[
          { step: 'Plan', title: '기획', desc: '요구사항 분석, 시장 조사, PRD 작성', icon: '📋', agents: 'Planner, Analyst' },
          { step: 'Design', title: '설계·개발', desc: '아키텍처 설계, UI/UX, 코드 구현', icon: '💻', agents: 'Architect, Designer, Executor' },
          { step: 'Check', title: 'QA·보안', desc: '코드 리뷰, 테스트, 보안 감사', icon: '🔍', agents: 'Verifier, Security Reviewer' },
          { step: 'Act', title: '개선·배포', desc: '피드백 반영, 최적화, 안정적 배포', icon: '🚀', agents: 'Code Simplifier, Git Master' },
        ].map(item => (
          <div class="bg-surface border border-border-light rounded-card p-6 text-center transition-all hover:-translate-y-1 hover:border-primary/20 relative overflow-hidden">
            <div class="text-2xl mb-3">{item.icon}</div>
            <div class="text-xs font-bold text-primary mb-2 tracking-wider">{item.step}</div>
            <h3 class="text-base font-bold text-text-main mb-2">{item.title}</h3>
            <p class="text-xs text-text-sub leading-relaxed mb-3">{item.desc}</p>
            <p class="text-[0.6rem] text-text-muted">{item.agents}</p>
          </div>
        ))}
      </div>

      <!-- Cycle indicator -->
      <div class="mt-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface border border-border-light text-xs text-text-muted">
          <span>Plan → Design → Check → Act</span>
          <span class="text-primary">↻</span>
          <span>설계-구현 일치율 90% 이상 통과 시 배포</span>
        </div>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Work Methodology -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-10">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">How We Work</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">작업 방식</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          {
            icon: '🤖',
            title: 'AI 에이전트 조직',
            desc: '20개 이상의 전문 AI 에이전트가 기획, 개발, QA, 보안 검토를 담당합니다. 단순한 도구 활용이 아닌, 체계적인 AI 조직을 운영합니다.',
          },
          {
            icon: '💬',
            title: '투명한 커뮤니케이션',
            desc: '진행 단계마다 공유합니다. 피그마 시안, 개발 진행 상황, 배포 결과까지 클라이언트가 항상 현황을 파악할 수 있습니다.',
          },
          {
            icon: '📐',
            title: '디테일 우선',
            desc: '반응형, 접근성, 로딩 속도, SEO까지 기본으로 챙깁니다. 눈에 보이지 않는 부분이 제품의 완성도를 결정한다고 믿습니다.',
          },
          {
            icon: '🔄',
            title: '무제한 수정',
            desc: '핵심 기능 범위 내에서 수정은 무제한입니다. 클라이언트가 만족할 때까지 함께 다듬습니다.',
          },
        ].map(item => (
          <div class="bg-surface border border-border-light rounded-card p-7 transition-all hover:-translate-y-1 hover:border-primary/20 hover:shadow-[0_8px_32px_rgba(0,0,0,0.2)] relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/[0.03] to-transparent pointer-events-none"></div>
            <div class="relative">
              <div class="text-2xl mb-4">{item.icon}</div>
              <h3 class="text-base font-bold text-text-main mb-2">{item.title}</h3>
              <p class="text-sm text-text-sub leading-relaxed break-keep">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Tech Stack -->
  <section class="py-16 px-7">
    <div class="max-w-content mx-auto">
      <div class="mb-10">
        <p class="text-[0.72rem] tracking-[3px] text-primary uppercase mb-2.5 font-semibold">Tech Stack</p>
        <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold tracking-tight">사용 기술</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { category: 'Frontend', techs: ['React', 'Next.js', 'Astro', 'TypeScript', 'Tailwind CSS'] },
          { category: 'Backend', techs: ['Node.js', 'NestJS', 'FastAPI', 'Supabase', 'PostgreSQL'] },
          { category: 'DevOps & AI', techs: ['Cloudflare Pages', 'Vercel', 'Docker', 'Claude AI', 'GitHub Actions'] },
        ].map(group => (
          <div class="bg-surface border border-border-light rounded-card p-6">
            <h3 class="text-sm font-semibold text-primary mb-4">{group.category}</h3>
            <div class="flex flex-wrap gap-2">
              {group.techs.map(tech => (
                <span class="px-3 py-1.5 rounded-full bg-surface-light text-xs text-text-sub font-medium border border-border-light">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- CTA -->
  <section class="relative py-24 px-7 text-center overflow-hidden">
    <div class="absolute -top-[100px] left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-[radial-gradient(circle,rgba(99,102,241,0.25),transparent_60%)] pointer-events-none"></div>
    <div class="relative z-10 max-w-[600px] mx-auto">
      <p class="text-[0.72rem] tracking-[4px] text-primary uppercase mb-5 font-semibold">Let's Work Together</p>
      <h2 class="text-[clamp(1.8rem,3.5vw,2.4rem)] font-extrabold mb-4 break-keep">
        프로젝트, 지금 시작하세요
      </h2>
      <p class="text-text-sub mb-8 break-keep leading-relaxed text-[0.95rem]">
        아이디어만 있으면 충분합니다.<br />
        기획부터 배포까지, ONESTEP이 함께합니다.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2.5 px-9 py-4 rounded-full bg-gradient-to-r from-primary-deep to-primary text-white font-bold transition-all hover:-translate-y-1 hover:scale-[1.03] hover:shadow-[0_8px_40px_rgba(99,102,241,0.45)] shadow-[0_4px_24px_rgba(99,102,241,0.3)]"
        >
          프로젝트 문의하기 →
        </a>
        <a
          href="/projects"
          class="inline-flex items-center gap-2.5 px-9 py-4 rounded-full border border-border-light text-text-sub font-semibold transition-all hover:border-primary/30 hover:text-text-main hover:-translate-y-0.5"
        >
          포트폴리오 보기
        </a>
      </div>
    </div>
  </section>

</PageLayout>
