---
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

// Placeholder cards shown when no MD files exist yet
const placeholders = [
  {
    slug: '#',
    emoji: '🚀',
    gradient: 'from-indigo-500/30 to-purple-600/30',
    tag: 'LIVE',
    category: 'live',
    title: '프리랜서 매칭 플랫폼',
    titleKo: '프리랜서 매칭 플랫폼',
    description: '클라이언트와 개발자를 연결하는 실시간 매칭 서비스. 채팅, 견적, 계약까지 한 번에.',
    techs: ['Next.js', 'TypeScript', 'Supabase'],
  },
  {
    slug: '#',
    emoji: '🏪',
    gradient: 'from-emerald-500/30 to-teal-600/30',
    tag: '수주',
    category: 'wishket',
    title: '소상공인 예약 시스템',
    titleKo: '소상공인 예약 시스템',
    description: '카페·미용실 등 소상공인을 위한 온라인 예약 관리 솔루션.',
    techs: ['React', 'Node.js', 'PostgreSQL'],
  },
  {
    slug: '#',
    emoji: '📊',
    gradient: 'from-blue-500/30 to-cyan-600/30',
    tag: '랜딩페이지',
    category: 'landing',
    title: 'SaaS 제품 랜딩페이지',
    titleKo: 'SaaS 제품 랜딩페이지',
    description: '전환율 최적화 설계, A/B 테스트 적용. CTR 32% 향상 달성.',
    techs: ['Astro', 'Tailwind CSS'],
  },
  {
    slug: '#',
    emoji: '📱',
    gradient: 'from-pink-500/30 to-rose-600/30',
    tag: '앱/SaaS',
    category: 'app',
    title: '모바일 앱 대시보드',
    titleKo: '모바일 앱 대시보드',
    description: '크로스플랫폼 React Native 앱, 실시간 데이터 시각화 대시보드.',
    techs: ['React Native', 'FastAPI', 'MongoDB'],
  },
  {
    slug: '#',
    emoji: '🎮',
    gradient: 'from-amber-500/30 to-orange-600/30',
    tag: '도구/게임',
    category: 'tool',
    title: '미니 게임 웹앱',
    titleKo: '미니 게임 웹앱',
    description: '브라우저 기반 퍼즐 게임. Canvas API와 물리 엔진 적용.',
    techs: ['Vanilla JS', 'Canvas API'],
  },
  {
    slug: '#',
    emoji: '🛒',
    gradient: 'from-violet-500/30 to-fuchsia-600/30',
    tag: '수주',
    category: 'wishket',
    title: '이커머스 쇼핑몰',
    titleKo: '이커머스 쇼핑몰',
    description: '결제 연동, 재고 관리, 관리자 대시보드가 포함된 풀스택 쇼핑몰.',
    techs: ['Next.js', 'NestJS', 'Stripe'],
  },
];

const usePlaceholders = sorted.length === 0;
---

<PageLayout title="프로젝트 — ONESTEP">
  <!-- Page Header -->
  <section class="relative pt-16 pb-10 px-7 text-center overflow-hidden">
    <div class="absolute -top-[150px] left-1/2 -translate-x-1/2 w-[700px] h-[600px] bg-[radial-gradient(circle,rgba(99,102,241,0.20),transparent_65%)] pointer-events-none"></div>
    <div class="relative z-10 max-w-content mx-auto">
      <p class="text-[0.72rem] tracking-[4px] text-primary uppercase mb-3 font-semibold">PROJECTS</p>
      <h1 class="text-[clamp(2rem,5vw,3rem)] font-black tracking-tight mb-4">프로젝트</h1>
      <p class="text-text-sub text-[0.95rem] leading-relaxed break-keep">
        102개 프로젝트의 경험이 담긴 포트폴리오입니다.<br class="hidden sm:block" />
        위시켓 수주 11건, LIVE 서비스 3개 운영 중.
      </p>
    </div>
  </section>

  <!-- Filter + Search -->
  <section class="px-7 pb-10 sticky top-16 z-20 bg-[#0B1120]/90 backdrop-blur-md border-b border-border-light">
    <div class="max-w-content mx-auto py-4 flex flex-col sm:flex-row gap-4 items-start sm:items-center justify-between">
      <!-- Category pills -->
      <div class="flex flex-wrap gap-2" id="categoryFilters">
        {[
          { key: 'all', label: '전체' },
          { key: 'live', label: 'LIVE' },
          { key: 'wishket', label: '수주 프로젝트' },
          { key: 'landing', label: '랜딩페이지' },
          { key: 'app', label: '앱/SaaS' },
          { key: 'tool', label: '도구/게임' },
        ].map(({ key, label }) => (
          <button
            data-category={key}
            class:list={[
              'category-btn px-4 py-1.5 rounded-full text-sm font-medium transition-all border',
              key === 'all'
                ? 'bg-gradient-to-r from-primary-deep to-primary text-white border-primary shadow-[0_2px_12px_rgba(99,102,241,0.35)]'
                : 'bg-surface border-border-light text-text-sub hover:border-primary/30 hover:text-text-main',
            ]}
          >
            {label}
          </button>
        ))}
      </div>

      <!-- Search -->
      <div class="relative w-full sm:w-[240px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-muted pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="searchInput"
          type="text"
          placeholder="프로젝트 검색..."
          class="w-full pl-9 pr-4 py-2 rounded-full bg-surface border border-border-light text-sm text-text-main placeholder:text-text-muted outline-none focus:border-primary/50 focus:shadow-[0_0_0_3px_rgba(99,102,241,0.1)] transition-all"
        />
      </div>
    </div>

    <!-- Count -->
    <div class="max-w-content mx-auto pb-2">
      <p class="text-xs text-text-muted" id="projectCount">
        총 {usePlaceholders ? placeholders.length : sorted.length}개 프로젝트
      </p>
    </div>
  </section>

  <!-- Grid -->
  <section class="px-7 py-12">
    <div class="max-w-content mx-auto">
      <div id="projectGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

        {usePlaceholders ? placeholders.map((p) => (
          <a
            href={p.slug}
            data-category={p.category}
            data-title={p.titleKo}
            data-techs={p.techs.join(' ')}
            class="project-card group bg-surface border border-border-light rounded-card overflow-hidden transition-all hover:-translate-y-1.5 hover:border-primary/25 hover:shadow-[0_12px_40px_rgba(0,0,0,0.3)]"
          >
            <!-- Thumbnail -->
            <div class:list={['relative h-44 bg-gradient-to-br flex items-center justify-center text-5xl', p.gradient]}>
              {p.tag === 'LIVE' && (
                <span class="absolute top-3 left-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface/80 backdrop-blur-sm border border-live/30 text-live text-[0.65rem] font-bold tracking-wide">
                  <span class="w-1.5 h-1.5 rounded-full bg-live animate-pulse"></span>
                  LIVE
                </span>
              )}
              {p.tag === '수주' && (
                <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-surface/80 backdrop-blur-sm border border-amber-400/30 text-amber-400 text-[0.65rem] font-bold tracking-wide">
                  수주
                </span>
              )}
              <span>{p.emoji}</span>
            </div>

            <!-- Content -->
            <div class="p-5">
              <span class="inline-block text-[0.68rem] font-semibold text-primary tracking-wider uppercase mb-2">{p.tag}</span>
              <h3 class="text-base font-bold text-text-main mb-1.5 leading-snug group-hover:text-primary transition-colors">{p.titleKo}</h3>
              <p class="text-xs text-text-sub leading-relaxed mb-4 line-clamp-2">{p.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {p.techs.map(t => (
                  <span class="px-2.5 py-0.5 rounded-full bg-surface-light text-[0.7rem] text-text-muted border border-border-light">{t}</span>
                ))}
              </div>
              <span class="inline-flex items-center gap-1 text-xs text-primary font-semibold group-hover:gap-2 transition-all">
                자세히 보기 <span>→</span>
              </span>
            </div>
          </a>
        )) : sorted.map((p) => (
          <a
            href={`/projects/${p.id}`}
            data-category={p.data.category}
            data-title={p.data.titleKo}
            data-techs={p.data.techs.join(' ')}
            class="project-card group bg-surface border border-border-light rounded-card overflow-hidden transition-all hover:-translate-y-1.5 hover:border-primary/25 hover:shadow-[0_12px_40px_rgba(0,0,0,0.3)]"
          >
            <!-- Thumbnail -->
            <div class="relative h-44 bg-gradient-to-br from-primary/20 to-primary-deep/30 overflow-hidden">
              <img src={`/screenshots/thumbs/${p.id}.webp`} alt={p.data.titleKo} class="w-full h-full object-cover object-top" loading="lazy"
                onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              <div class="hidden items-center justify-center absolute inset-0 text-5xl">🚀</div>
              {p.data.category === 'live' && (
                <span class="absolute top-3 left-3 flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-surface/80 backdrop-blur-sm border border-live/30 text-live text-[0.65rem] font-bold tracking-wide">
                  <span class="w-1.5 h-1.5 rounded-full bg-live animate-pulse"></span>
                  LIVE
                </span>
              )}
              {p.data.category === 'wishket' && (
                <span class="absolute top-3 left-3 px-2.5 py-1 rounded-full bg-surface/80 backdrop-blur-sm border border-amber-400/30 text-amber-400 text-[0.65rem] font-bold tracking-wide">
                  수주
                </span>
              )}
            </div>

            <!-- Content -->
            <div class="p-5">
              <span class="inline-block text-[0.68rem] font-semibold text-primary tracking-wider uppercase mb-2">{p.data.tag}</span>
              <h3 class="text-base font-bold text-text-main mb-1.5 leading-snug group-hover:text-primary transition-colors">{p.data.titleKo}</h3>
              <p class="text-xs text-text-sub leading-relaxed mb-4 line-clamp-2">{p.data.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-4">
                {p.data.techs.map(t => (
                  <span class="px-2.5 py-0.5 rounded-full bg-surface-light text-[0.7rem] text-text-muted border border-border-light">{t}</span>
                ))}
              </div>
              <span class="inline-flex items-center gap-1 text-xs text-primary font-semibold group-hover:gap-2 transition-all">
                자세히 보기 <span>→</span>
              </span>
            </div>
          </a>
        ))}

      </div>

      <!-- Empty state -->
      <div id="emptyState" class="hidden text-center py-24">
        <p class="text-4xl mb-4">🔍</p>
        <p class="text-text-sub">검색 결과가 없습니다.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 px-7 text-center overflow-hidden">
    <div class="absolute -top-[80px] left-1/2 -translate-x-1/2 w-[500px] h-[300px] bg-[radial-gradient(circle,rgba(99,102,241,0.18),transparent_60%)] pointer-events-none"></div>
    <div class="relative z-10 max-w-[560px] mx-auto">
      <h2 class="text-[clamp(1.6rem,3vw,2.2rem)] font-extrabold mb-4 break-keep">다음 프로젝트는 당신의 것</h2>
      <p class="text-text-sub mb-8 break-keep leading-relaxed text-sm">
        아이디어만 있으면 충분합니다. 지금 바로 문의해 주세요.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2.5 px-8 py-3.5 rounded-full bg-gradient-to-r from-primary-deep to-primary text-white font-bold transition-all hover:-translate-y-1 hover:scale-[1.03] hover:shadow-[0_8px_40px_rgba(99,102,241,0.45)] shadow-[0_4px_24px_rgba(99,102,241,0.3)] text-sm"
      >
        프로젝트 문의하기 <span>→</span>
      </a>
    </div>
  </section>

  <script>
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.project-card'));
    const countEl = document.getElementById('projectCount')!;
    const emptyEl = document.getElementById('emptyState')!;
    const grid = document.getElementById('projectGrid')!;

    let activeCategory = 'all';
    let searchQuery = '';

    function updateCount(n: number) {
      countEl.textContent = `총 ${n}개 프로젝트`;
    }

    function applyFilters() {
      let visible = 0;
      cards.forEach(card => {
        const cat = card.dataset.category ?? '';
        const title = (card.dataset.title ?? '').toLowerCase();
        const techs = (card.dataset.techs ?? '').toLowerCase();
        const q = searchQuery.toLowerCase();

        const matchCat = activeCategory === 'all' || cat === activeCategory;
        const matchSearch = q === '' || title.includes(q) || techs.includes(q);

        if (matchCat && matchSearch) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      updateCount(visible);
      emptyEl.classList.toggle('hidden', visible > 0);
    }

    // Category buttons
    document.querySelectorAll<HTMLButtonElement>('.category-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category ?? 'all';
        document.querySelectorAll<HTMLButtonElement>('.category-btn').forEach(b => {
          const isActive = b.dataset.category === activeCategory;
          b.className = b.className
            .replace(/bg-gradient-to-r from-primary-deep to-primary text-white border-primary shadow-\[0_2px_12px_rgba\(99,102,241,0\.35\)\]/, '')
            .replace(/bg-surface border-border-light text-text-sub hover:border-primary\/30 hover:text-text-main/, '')
            .trim();
          if (isActive) {
            b.classList.add('bg-gradient-to-r', 'from-primary-deep', 'to-primary', 'text-white', 'border-primary', 'shadow-[0_2px_12px_rgba(99,102,241,0.35)]');
            b.classList.remove('bg-surface', 'border-border-light', 'text-text-sub', 'hover:border-primary/30', 'hover:text-text-main');
          } else {
            b.classList.add('bg-surface', 'border-border-light', 'text-text-sub', 'hover:border-primary/30', 'hover:text-text-main');
            b.classList.remove('bg-gradient-to-r', 'from-primary-deep', 'to-primary', 'text-white', 'border-primary', 'shadow-[0_2px_12px_rgba(99,102,241,0.35)]');
          }
        });
        applyFilters();
      });
    });

    // Search
    document.getElementById('searchInput')!.addEventListener('input', (e) => {
      searchQuery = (e.target as HTMLInputElement).value;
      applyFilters();
    });
  </script>
</PageLayout>
