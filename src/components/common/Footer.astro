---
const currentYear = new Date().getFullYear();
const email = 'wogns5486@gmail.com';

const navGroups = [
  {
    title: '서비스',
    links: [
      { label: '프로젝트', href: '/projects' },
      { label: '회사 소개', href: '/about' },
      { label: '블로그', href: '/blog' },
    ],
  },
  {
    title: 'LIVE 서비스',
    links: [
      { label: 'DriveX', href: 'https://drivex-4kh.pages.dev/', external: true },
      { label: 'SignTrack', href: 'https://signtrack.net/', external: true },
    ],
  },
  {
    title: '문의',
    links: [
      { label: '프로젝트 문의', href: '/contact' },
      { label: '이메일', href: `mailto:${email}` },
    ],
  },
];
---

<footer class="border-t border-border-light mt-auto">
  <div class="max-w-content mx-auto px-7 py-16">
    <!-- Top -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="text-xl font-bold text-text-main">ONESTEP</a>
        <p class="mt-3 text-sm text-text-muted leading-relaxed">
          웹·앱 개발, 합리적인 가격으로.<br />기획부터 배포까지 한 번에.
        </p>
      </div>

      <!-- Nav Groups -->
      {navGroups.map(group => (
        <div>
          <h4 class="text-sm font-semibold text-text-sub mb-4">{group.title}</h4>
          <ul class="flex flex-col gap-3">
            {group.links.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-text-muted hover:text-text-main transition-colors"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                  {link.external && <span class="text-xs ml-1">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="h-px bg-border-light mb-8"></div>

    <!-- Bottom -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-text-muted">
        &copy; {currentYear} ONESTEP. All rights reserved.
      </p>
      <button
        id="copy-email"
        class="text-xs text-text-muted hover:text-primary transition-colors cursor-pointer"
        data-email={email}
      >
        {email} — 클릭하여 복사
      </button>
    </div>
  </div>
</footer>

<script>
  const btn = document.getElementById('copy-email');
  if (btn) {
    btn.addEventListener('click', async () => {
      const email = btn.dataset.email!;
      await navigator.clipboard.writeText(email);
      const original = btn.textContent;
      btn.textContent = '✓ 복사되었습니다';
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  }
</script>
